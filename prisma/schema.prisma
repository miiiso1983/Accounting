// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CurrencyCode {
  IQD
  USD
}

enum Dc {
  DEBIT
  CREDIT
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

enum JournalEntryType {
  SYSTEM
  MANUAL
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  CLOSED
  WRITTEN_OFF
}

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
  REJECTED
}

enum AttachmentOwnerType {
  INVOICE
  EXPENSE
}

enum PrintTemplateType {
  INVOICE
  RECEIPT
  JOURNAL_ENTRY
}

enum InstallmentFrequency {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum InstallmentContractStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Company {
  id                String        @id @default(cuid())
  name              String
  baseCurrencyCode  CurrencyCode  @default(IQD)
  secondaryCurrency CurrencyCode? @default(USD)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  users                User[]
  glAccounts           GlAccount[]
  exchangeRates        ExchangeRate[]
  customers            Customer[]
  invoices             Invoice[]
  invoicePayments      InvoicePayment[]
  expenses             Expense[]
  journalEntries       JournalEntry[]
  attachments          Attachment[]
  products             Product[]
  costCenters          CostCenter[]
  branches             Branch[]
  printTemplates       PrintTemplate[]
  installmentContracts InstallmentContract[]
  salesRepresentatives SalesRepresentative[]
  estimates            Estimate[]
  creditNotes          CreditNote[]
}

// --- Auth.js / NextAuth v4 models (Prisma Adapter) ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  isActive      Boolean   @default(true)

  // Credentials auth support
  passwordHash String?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Default branch preference (optional for backward compatibility)
  defaultBranchId String?
  defaultBranch   Branch? @relation("UserDefaultBranch", fields: [defaultBranchId], references: [id], onDelete: SetNull)

  accounts    Account[]
  sessions    Session[]
  roles       UserRole[]
  permissions UserPermission[]

  // Operational links
  createdJournalEntries  JournalEntry[]
  createdInvoicePayments InvoicePayment[]
  createdEstimates       Estimate[]
  createdCreditNotes     CreditNote[]
  uploadedAttachments    Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([defaultBranchId])
}

// NOTE: NextAuth Prisma Adapter expects this model to be named `Account`.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- RBAC ---

model Role {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  description String?

  roles RolePermission[]
  users UserPermission[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model UserPermission {
  userId       String
  permissionId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// --- Accounting core ---

model ExchangeRate {
  id                String       @id @default(cuid())
  companyId         String
  baseCurrencyCode  CurrencyCode
  quoteCurrencyCode CurrencyCode

  // 1 baseCurrencyCode = rate quoteCurrencyCode
  rate        Decimal  @db.Decimal(20, 8)
  effectiveAt DateTime
  source      String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Inverse relations
  journalEntries  JournalEntry[]
  invoices        Invoice[]
  estimates       Estimate[]
  creditNotes     CreditNote[]
  expenses        Expense[]
  invoicePayments InvoicePayment[]

  @@index([companyId, baseCurrencyCode, quoteCurrencyCode, effectiveAt])
}

// General Ledger (Chart of Accounts)
model GlAccount {
  id        String @id @default(cuid())
  companyId String

  code          String
  name          String
  type          AccountType
  subType       String?
  normalBalance Dc

  parentId String?
  parent   GlAccount?  @relation("AccountTree", fields: [parentId], references: [id])
  children GlAccount[] @relation("AccountTree")

  isPosting Boolean @default(true)

  // Optional: currency-denominated account (e.g., USD bank account)
  currencyCode CurrencyCode?

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]

  // Inverse relation for Expense.expenseAccount
  expenses Expense[]

  // Inverse relation for ExpenseLineItem.account
  expenseLineItems ExpenseLineItem[]

  // Inverse relation for Product.revenueAccount
  revenueProducts Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId, type])
  @@index([companyId, parentId])
}

model JournalEntry {
  id          String             @id @default(cuid())
  companyId   String
  entryNumber Int                @default(0)
  type        JournalEntryType   @default(MANUAL)
  status      JournalEntryStatus @default(DRAFT)

  // Optional branch (nullable to support existing data)
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  entryDate   DateTime
  description String?

  // Snapshot of reporting/base currency used for conversion
  baseCurrencyCode CurrencyCode

  // Optional: transaction currency for the entry
  currencyCode   CurrencyCode?
  exchangeRateId String?
  exchangeRate   ExchangeRate? @relation(fields: [exchangeRateId], references: [id])

  referenceType String?
  referenceId   String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   JournalLine[]

  // Optional links from documents
  invoices        Invoice[]
  expenses        Expense[]
  invoicePayments InvoicePayment[]
  creditNotes     CreditNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, type, entryNumber])
  @@index([companyId, entryDate])
  @@index([companyId, branchId])
  @@index([companyId, type])
  @@index([companyId, status])
}

model JournalLine {
  id             String @id @default(cuid())
  journalEntryId String
  accountId      String

  costCenterId String?

  dc           Dc
  // amount in the line currency
  amount       Decimal      @db.Decimal(20, 6)
  currencyCode CurrencyCode

  // amount converted to entry.baseCurrencyCode at posting time
  amountBase  Decimal @db.Decimal(20, 6)
  description String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      GlAccount    @relation(fields: [accountId], references: [id])
  costCenter   CostCenter?  @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([costCenterId])
}

model CostCenter {
  id        String @id @default(cuid())
  companyId String

  code     String
  name     String
  isActive Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  journalLines      JournalLine[]
  products          Product[]
  expenses          Expense[]
  expenseLineItems  ExpenseLineItem[]
  invoiceLineItems  InvoiceLineItem[]
  estimateLineItems EstimateLineItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@index([companyId, name])
}

model Branch {
  id        String @id @default(cuid())
  companyId String

  code     String
  name     String
  address  String?
  phone    String?
  isActive Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Inverse relations
  invoices       Invoice[]
  estimates      Estimate[]
  creditNotes    CreditNote[]
  journalEntries JournalEntry[]
  defaultUsers   User[]         @relation("UserDefaultBranch")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@index([companyId, name])
}

model PrintTemplate {
  id        String @id @default(cuid())
  companyId String

  name       String
  type       PrintTemplateType
  headerHtml String            @db.Text
  footerHtml String            @db.Text
  logoUrl    String?
  isDefault  Boolean           @default(false)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, type])
  @@index([companyId, isDefault])
  @@index([companyId, name])
}

// --- Products/Items ---

model Product {
  id           String       @id @default(cuid())
  companyId    String
  name         String
  description  String?
  unitPrice    Decimal      @db.Decimal(20, 6)
  currencyCode CurrencyCode @default(IQD)
  isActive     Boolean      @default(true)

  costCenterId     String?
  revenueAccountId String?

  company        Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  costCenter     CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  revenueAccount GlAccount?  @relation(fields: [revenueAccountId], references: [id], onDelete: SetNull)
  expenses           Expense[]
  invoiceLineItems   InvoiceLineItem[]
  estimateLineItems  EstimateLineItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, isActive])
  @@index([companyId, name])
  @@index([companyId, costCenterId])
}

// --- Sales Representatives ---

model SalesRepresentative {
  id        String  @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  isActive  Boolean @default(true)

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, isActive])
  @@index([companyId, name])
}

// --- Sales/Invoicing ---

model Customer {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  companyName String?
  email       String?
  phone       String?
  address1    String?
  address2    String?
  city        String?
  country     String?

  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices             Invoice[]
  estimates            Estimate[]
  installmentContracts InstallmentContract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, name])
}

model Invoice {
  id         String @id @default(cuid())
  companyId  String
  customerId String

  invoiceNumber String
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime
  dueDate       DateTime?

  currencyCode     CurrencyCode
  baseCurrencyCode CurrencyCode
  exchangeRateId   String?
  exchangeRate     ExchangeRate? @relation(fields: [exchangeRateId], references: [id])

  // Optional branch (nullable to support existing data)
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  subtotal       Decimal @db.Decimal(20, 6)
  discountType   String? // "PERCENTAGE" | "FIXED"
  discountValue  Decimal @default(0) @db.Decimal(20, 6)
  discountAmount Decimal @default(0) @db.Decimal(20, 6)
  taxTotal       Decimal @default(0) @db.Decimal(20, 6)
  total          Decimal @db.Decimal(20, 6)

  subtotalBase       Decimal @db.Decimal(20, 6)
  discountAmountBase Decimal @default(0) @db.Decimal(20, 6)
  taxTotalBase       Decimal @default(0) @db.Decimal(20, 6)
  totalBase          Decimal @db.Decimal(20, 6)

  paymentTerms String? // "MONTHLY" | "QUARTERLY" | "YEARLY"
  templateKey  String? // for customizable templates
  qrPayload    String?

  salesRepresentativeId String?
  salesRepresentative   SalesRepresentative? @relation(fields: [salesRepresentativeId], references: [id], onDelete: SetNull)

  customer    Customer          @relation(fields: [customerId], references: [id])
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lineItems   InvoiceLineItem[]
  attachments Attachment[]
  payments    InvoicePayment[]
  creditNotes CreditNote[]

  // Inverse: estimate that was converted to this invoice
  sourceEstimate Estimate? @relation("EstimateToInvoice")

  // Optional linkage to posted accounting entry
  journalEntryId String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, invoiceNumber])
  @@index([companyId, issueDate])
  @@index([companyId, branchId])
  @@index([companyId, status])
  @@index([companyId, salesRepresentativeId])
}

model InvoicePayment {
  id            String @id @default(cuid())
  companyId     String
  invoiceId     String
  receiptNumber Int?

  paymentDate DateTime
  method      String? // CASH | BANK | TRANSFER ...
  note        String?

  amount       Decimal      @db.Decimal(20, 6)
  currencyCode CurrencyCode

  // Snapshot of base currency used for conversion at posting time
  baseCurrencyCode CurrencyCode
  exchangeRateId   String?
  exchangeRate     ExchangeRate? @relation(fields: [exchangeRateId], references: [id])
  amountBase       Decimal       @db.Decimal(20, 6)

  // Optional linkage to posted accounting entry
  journalEntryId String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, receiptNumber])
  @@index([companyId, paymentDate])
  @@index([companyId, invoiceId])
}

model InvoiceLineItem {
  id            String   @id @default(cuid())
  invoiceId     String
  description   String
  quantity      Decimal  @db.Decimal(20, 6)
  unitPrice     Decimal  @db.Decimal(20, 6)
  discountType  String? // "PERCENTAGE" | "FIXED"
  discountValue Decimal  @default(0) @db.Decimal(20, 6)
  lineTotal     Decimal  @db.Decimal(20, 6)
  taxRate       Decimal? @db.Decimal(20, 6) // e.g. 0.05

  costCenterId String?
  productId    String?

  invoice    Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  product    Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([costCenterId])
  @@index([productId])
}

model InstallmentContract {
  id         String @id @default(cuid())
  companyId  String
  customerId String

  productName   String
  invoiceNumber String
  invoiceDate   DateTime

  durationMonths Int
  totalAmount    Decimal      @db.Decimal(20, 6)
  currencyCode   CurrencyCode

  installmentFrequency InstallmentFrequency
  numberOfInstallments Int
  amountPerInstallment Decimal                   @db.Decimal(20, 6)
  status               InstallmentContractStatus @default(ACTIVE)

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, invoiceNumber])
  @@index([companyId, invoiceDate])
  @@index([companyId, customerId])
  @@index([companyId, status])
}

// --- Expenses ---

model Expense {
  id        String @id @default(cuid())
  companyId String

  expenseNumber String?
  status        ExpenseStatus @default(DRAFT)
  expenseDate   DateTime

  vendorName  String?
  description String?

  // Optional link to the product/item this expense was spent on
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  currencyCode     CurrencyCode
  baseCurrencyCode CurrencyCode
  exchangeRateId   String?
  exchangeRate     ExchangeRate? @relation(fields: [exchangeRateId], references: [id])

  total     Decimal @db.Decimal(20, 6)
  totalBase Decimal @db.Decimal(20, 6)

  // Suggested posting account (e.g., expense category)
  expenseAccountId String?
  expenseAccount   GlAccount? @relation(fields: [expenseAccountId], references: [id])

  // Optional linkage to posted accounting entry
  journalEntryId String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  lineItems   ExpenseLineItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, expenseNumber])
  @@index([companyId, expenseDate])
  @@index([companyId, status])
  @@index([companyId, productId])
  @@index([companyId, costCenterId])
}

model ExpenseLineItem {
  id        String @id @default(cuid())
  expenseId String

  accountId String
  account   GlAccount @relation(fields: [accountId], references: [id])

  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  description String?
  amount      Decimal @db.Decimal(20, 6)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
}

// --- Attachments (invoices + expenses) ---

model Attachment {
  id        String              @id @default(cuid())
  companyId String
  ownerType AttachmentOwnerType

  invoiceId String?
  expenseId String?

  originalName String
  mimeType     String
  sizeBytes    Int

  // Storage reference (local path or object key)
  storageKey String

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  expense Expense? @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([companyId, ownerType])
  @@index([invoiceId])
  @@index([expenseId])
}


// --- Estimates (عروض الأسعار) ---

model Estimate {
  id         String @id @default(cuid())
  companyId  String
  customerId String

  estimateNumber String
  status         EstimateStatus @default(DRAFT)
  issueDate      DateTime
  expiryDate     DateTime?

  currencyCode     CurrencyCode
  baseCurrencyCode CurrencyCode
  exchangeRateId   String?
  exchangeRate     ExchangeRate? @relation(fields: [exchangeRateId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  subtotal       Decimal @db.Decimal(20, 6)
  discountType   String? // "PERCENTAGE" | "FIXED"
  discountValue  Decimal @default(0) @db.Decimal(20, 6)
  discountAmount Decimal @default(0) @db.Decimal(20, 6)
  taxTotal       Decimal @default(0) @db.Decimal(20, 6)
  total          Decimal @db.Decimal(20, 6)

  subtotalBase       Decimal @db.Decimal(20, 6)
  discountAmountBase Decimal @default(0) @db.Decimal(20, 6)
  taxTotalBase       Decimal @default(0) @db.Decimal(20, 6)
  totalBase          Decimal @db.Decimal(20, 6)

  note String?

  // Link to converted invoice (when status = CONVERTED)
  convertedInvoiceId String?  @unique
  convertedInvoice   Invoice? @relation("EstimateToInvoice", fields: [convertedInvoiceId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User? @relation(fields: [createdById], references: [id])

  customer  Customer          @relation(fields: [customerId], references: [id])
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lineItems EstimateLineItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, estimateNumber])
  @@index([companyId, issueDate])
  @@index([companyId, branchId])
  @@index([companyId, status])
}

model EstimateLineItem {
  id            String  @id @default(cuid())
  estimateId    String
  description   String
  quantity      Decimal @db.Decimal(20, 6)
  unitPrice     Decimal @db.Decimal(20, 6)
  discountType  String? // "PERCENTAGE" | "FIXED"
  discountValue Decimal @default(0) @db.Decimal(20, 6)
  lineTotal     Decimal @db.Decimal(20, 6)
  taxRate       Decimal? @db.Decimal(20, 6) // e.g. 0.05

  costCenterId String?
  productId    String?

  estimate   Estimate    @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  product    Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([estimateId])
  @@index([costCenterId])
  @@index([productId])
}

// --- Credit Notes (إشعارات دائنة / مردودات) ---

model CreditNote {
  id         String @id @default(cuid())
  companyId  String
  invoiceId  String

  creditNoteNumber String
  issueDate        DateTime

  currencyCode     CurrencyCode
  baseCurrencyCode CurrencyCode
  exchangeRateId   String?
  exchangeRate     ExchangeRate? @relation(fields: [exchangeRateId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  subtotal  Decimal @db.Decimal(20, 6)
  taxTotal  Decimal @default(0) @db.Decimal(20, 6)
  total     Decimal @db.Decimal(20, 6)

  subtotalBase Decimal @db.Decimal(20, 6)
  taxTotalBase Decimal @default(0) @db.Decimal(20, 6)
  totalBase    Decimal @db.Decimal(20, 6)

  reason String?

  // Linkage to posted accounting entry
  journalEntryId String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  createdById String?
  createdBy   User? @relation(fields: [createdById], references: [id])

  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice   Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineItems CreditNoteLineItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, creditNoteNumber])
  @@index([companyId, issueDate])
  @@index([companyId, invoiceId])
  @@index([companyId, branchId])
}

model CreditNoteLineItem {
  id           String  @id @default(cuid())
  creditNoteId String
  description  String
  quantity     Decimal @db.Decimal(20, 6)
  unitPrice    Decimal @db.Decimal(20, 6)
  lineTotal    Decimal @db.Decimal(20, 6)
  taxRate      Decimal? @db.Decimal(20, 6)

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
}